{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paper-fetch-skill.local/schemas/onboarding-state.v1.json",
  "title": "ProviderOnboardingCoordinatorState v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "agent_cli", "active_provider", "providers"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "agent_cli": {
      "type": ["string", "null"]
    },
    "active_provider": {
      "oneOf": [
        {"$ref": "#/$defs/provider_name"},
        {"type": "null"}
      ]
    },
    "providers": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/provider_state"
      }
    }
  },
  "$defs": {
    "provider_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "task_id": {
      "enum": [
        "discover-manifest",
        "validate-manifest",
        "capture-fixtures",
        "scaffold",
        "implement-provider",
        "snapshot-expected",
        "manifest-sync-back",
        "provider-local-acceptance",
        "global-lint",
        "merge-ready"
      ]
    },
    "task_status": {
      "enum": ["pending", "in_progress", "completed", "failed", "blocked"]
    },
    "provider_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "manifest",
        "status",
        "current_step",
        "steps",
        "completed_steps",
        "task_statuses",
        "retry_counts",
        "verifications"
      ],
      "properties": {
        "provider": {
          "$ref": "#/$defs/provider_name"
        },
        "manifest": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["in_progress", "blocked", "merge_ready", "completed"]
        },
        "current_step": {
          "oneOf": [
            {"$ref": "#/$defs/task_id"},
            {"type": "null"}
          ]
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/task_id"
          }
        },
        "completed_steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task_id"
          }
        },
        "task_statuses": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/task_id"
          },
          "additionalProperties": {
            "$ref": "#/$defs/task_status"
          }
        },
        "retry_counts": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/task_id"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3
          }
        },
        "verifications": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "required": ["dry_run", "commands", "result"],
            "properties": {
              "dry_run": {
                "const": true
              },
              "commands": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "result": {
                "enum": ["planned"]
              }
            }
          }
        }
      }
    }
  }
}
