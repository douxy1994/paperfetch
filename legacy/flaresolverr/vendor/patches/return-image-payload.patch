+def extract_loaded_image_payload(driver: WebDriver) -> dict | None:
+    try:
+        return driver.execute_script("""
+            const bytesToBase64 = (bytes) => {
+                let binary = '';
+                const chunkSize = 0x8000;
+                for (let index = 0; index < bytes.length; index += chunkSize) {
+                    const chunk = bytes.subarray(index, index + chunkSize);
+                    binary += String.fromCharCode(...chunk);
+                }
+                return btoa(binary);
+            };
+            const normalizeUrl = (value) => {
+                try {
+                    return new URL(String(value || ''), document.baseURI).href;
+                } catch (error) {
+                    return String(value || '');
+                }
+            };
+            const svgDimension = (root, name) => {
+                const raw = String((root && root.getAttribute && root.getAttribute(name)) || '').trim();
+                const parsed = Number.parseFloat(raw);
+                if (Number.isFinite(parsed) && parsed > 0) {
+                    return parsed;
+                }
+                try {
+                    const viewBox = root && root.viewBox && root.viewBox.baseVal;
+                    const value = name === 'width' ? viewBox.width : viewBox.height;
+                    if (Number.isFinite(value) && value > 0) {
+                        return value;
+                    }
+                } catch (error) {}
+                try {
+                    const rect = root && root.getBoundingClientRect && root.getBoundingClientRect();
+                    const value = name === 'width' ? rect.width : rect.height;
+                    if (Number.isFinite(value) && value > 0) {
+                        return value;
+                    }
+                } catch (error) {}
+                return 0;
+            };
+            const documentElement = document.documentElement;
+            const isSvgDocument = documentElement
+                && String(documentElement.localName || documentElement.tagName || '').toLowerCase() === 'svg';
+            if (isSvgDocument) {
+                try {
+                    const serializer = new XMLSerializer();
+                    const bodyText = serializer.serializeToString(documentElement);
+                    const encoder = new TextEncoder();
+                    const bodyB64 = bytesToBase64(encoder.encode(bodyText));
+                    if (bodyB64) {
+                        return {
+                            ok: true,
+                            status: 200,
+                            url: normalizeUrl(document.location.href),
+                            contentType: 'image/svg+xml',
+                            bodyB64,
+                            width: svgDimension(documentElement, 'width'),
+                            height: svgDimension(documentElement, 'height'),
+                        };
+                    }
+                } catch (error) {
+                    return {
+                        ok: false,
+                        reason: 'svg_serialization_failed',
+                        error: String((error && (error.name || error.message)) || error || ''),
+                        url: normalizeUrl(document.location.href),
+                        title: document.title || '',
+                        contentType: document.contentType || '',
+                    };
+                }
+            }
+            const images = Array.from(document.images || []);
+            const classifyCanvasError = (error) => {
+                const name = String((error && error.name) || '');
+                const message = String((error && error.message) || error || '');
+                const blob = `${name} ${message}`.toLowerCase();
+                if (
+                    name === 'SecurityError'
+                    || blob.includes('tainted')
+                    || blob.includes('cross-origin')
+                    || blob.includes('insecure operation')
+                ) {
+                    return {
+                        reason: 'canvas_tainted',
+                        error: name || message,
+                    };
+                }
+                return {
+                    reason: 'canvas_serialization_failed',
+                    error: name || message,
+                };
+            };
+            const normalizedTarget = normalizeUrl(document.location.href);
+            const loadedImages = images.filter((candidate) =>
+                candidate.complete
+                && candidate.naturalWidth >= 20
+                && candidate.naturalHeight >= 20
+            );
+            const image = loadedImages.find((candidate) =>
+                normalizedTarget
+                && normalizeUrl(candidate.currentSrc || candidate.src || '') === normalizedTarget
+            ) || loadedImages
+                .sort((left, right) =>
+                    (right.naturalWidth * right.naturalHeight)
+                    - (left.naturalWidth * left.naturalHeight)
+                )[0];
+            if (!image) {
+                return {
+                    ok: false,
+                    reason: 'no_loaded_image',
+                    url: normalizedTarget || normalizeUrl(document.location.href),
+                    title: document.title || '',
+                    contentType: document.contentType || '',
+                };
+            }
+            const chosenUrl = normalizeUrl(image.currentSrc || image.src || normalizedTarget || document.location.href);
+            const canvas = document.createElement('canvas');
+            canvas.width = image.naturalWidth || image.width || 0;
+            canvas.height = image.naturalHeight || image.height || 0;
+            const context = canvas.getContext('2d');
+            if (!context || !canvas.width || !canvas.height) {
+                return {
+                    ok: false,
+                    reason: 'missing_canvas_context',
+                    url: chosenUrl,
+                    title: document.title || '',
+                    contentType: document.contentType || '',
+                };
+            }
+            try {
+                context.drawImage(image, 0, 0);
+            } catch (error) {
+                const classified = classifyCanvasError(error);
+                return {
+                    ok: false,
+                    reason: classified.reason,
+                    error: classified.error,
+                    url: chosenUrl,
+                    title: document.title || '',
+                    contentType: document.contentType || '',
+                };
+            }
+            try {
+                const dataUrl = canvas.toDataURL('image/png');
+                const bodyB64 = String(dataUrl || '').split(',', 2)[1] || '';
+                if (!bodyB64) {
+                    return {
+                        ok: false,
+                        reason: 'canvas_serialization_failed',
+                        url: chosenUrl,
+                        title: document.title || '',
+                        contentType: document.contentType || '',
+                    };
+                }
+                return {
+                    ok: true,
+                    status: 200,
+                    url: chosenUrl,
+                    contentType: 'image/png',
+                    bodyB64,
+                    width: image.naturalWidth || canvas.width,
+                    height: image.naturalHeight || canvas.height,
+                };
+            } catch (error) {
+                const classified = classifyCanvasError(error);
+                return {
+                    ok: false,
+                    reason: classified.reason,
+                    error: classified.error,
+                    url: chosenUrl,
+                    title: document.title || '',
+                    contentType: document.contentType || '',
+                };
+            }
+        """)
+    except Exception as exc:
+        logging.debug("Loaded image payload extraction failed: %s", exc)
+        return None
+
